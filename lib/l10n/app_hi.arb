    "oscilloscopeBulletPoint1": "PSLab का ऑसिलोस्कोप एक प्रोफेशनल ऑसिलोस्कोप जैसी ही कई सुविधाएं देता है। इसमें MIC इनपुट के साथ 4 चैनल, 2 साइन वेव जनरेटर और 4 PWM स्क्वेयर वेव जनरेटर हैं। टाइमबेस बदला जा सकता है, सिग्नल एनालाइज़ होता है, साइन और स्क्वेयर वेव फिटिंग होती है, और चैनल-टू-चैनल वोल्टेज प्लॉट कर सकते हैं।",
    "oscilloscopeBulletPoint2": "साइन या स्क्वेयर वेव पढ़ने के लिए आउटपुट वेव पिन और एक चैनल को ऑसिलोस्कोप से नीचे दिखाए तरीके से जोड़ें।",
    "oscilloscopeBulletPoint3": "ऊपर की फोटो में SQ1 को CH1 से और SI1 को CH2 से जोड़ा गया है।",
    "oscilloscopeBulletPoint4": "वेव जनरेटर से वेव बनाने के बाद ज़रूरी पिन जोड़ें और चैनल पैरामीटर में सही चैनल टिक करके ऑसिलोस्कोप पर देखें। अगर CH1 पिन यूज़ कर रहे हैं तो चैनल पैरामीटर से CH1 चुनें।",
    "channelParameters": "चैनल पैरामीटर",
    "channelParametersIntro": "इस सेटिंग से वो चैनल बदल सकते हैं जो प्लॉट में दिखाना है।",
    "channelParametersBulletPoint1": "जिस चैनल को प्लॉट करना है उसका चेक बॉक्स टिक करें।",
    "channelParametersBulletPoint2": "चैनल के बगल वाले स्पिनर से प्लॉट की Y-अक्ष वोल्टेज रेंज बदल सकते हैं।",
    "channelParametersBulletPoint3": "चौथे चैनल के लिए अंदर वाला माइक या बाहरी माइक चुन सकते हैं। बाहरी माइक यूज़ करने पर कनेक्शन इस तरह होगा।",
    "channelParametersBulletPoint4": "माइक का प्लस टर्मिनल MIC पिन से और माइनस टर्मिनल PSLab के GND पिन से जोड़ें।",
    "timebaseIntro": "इस सेटिंग से टाइम अक्ष (X-अक्ष) की रेंज कंट्रोल कर सकते हैं।",
    "timebaseBulletPoint1": "टाइमबेस स्लाइडर से सिग्नल कैप्चर का टाइम बढ़ा-घटा सकते हैं। रेंज 875.0 माइक्रोसेकंड से 102.4 मिलीसेकंड तक है।",
    "timebaseBulletPoint2": "यह दी गई रेंज में पीरियोडिक वेव सिग्नल को एनालिसिस के लिए पकड़ने में काम आता है।",
    "timebaseBulletPoint3": "ट्रिगर से वोल्टेज वैल्यू सेट कर सकते हैं, जब सिग्नल उस वैल्यू से ज़्यादा हो तो प्लॉट रुक जाएगा।",
    "dataAnalysisBulletPoint1": "इस सेटिंग से एनालाइज़ किए सिग्नल का मैथमेटिकल फ़ंक्शन निकाल सकते हैं। वेव टाइप (साइन या स्क्वेयर) और एनालाइज़ करने वाला चैनल चुन सकते हैं।",
    "dataAnalysisBulletPoint2": "इसके अलावा फूरियर ट्रांसफॉर्म चेक बॉक्स टिक करके सिग्नल का फूरियर ट्रांसफॉर्म भी देख सकते हैं।",
    "xyPlotBulletPoint1": "इससे चैनल-टू-चैनल वोल्टेज को X-Y प्लॉट में दिखाया जाता है, जहां दोनों अक्ष की यूनिट उन चैनलों की वोल्टेज होती है।",
